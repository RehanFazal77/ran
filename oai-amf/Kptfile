  annotations:
    config.kubernetes.io/local-config: "true"
    internal.kpt.dev/upstream-identifier: 'kpt.dev|Kptfile|default|oai-amf'
upstream:
  type: git
  git:
    repo: https://github.com/RehanFazal77/nephio-workload-blueprints.git
    directory: workloads/oai-ran/oai-ran/oai-amf
    ref: main
upstreamLock:
  type: git
  git:
    repo: https://github.com/RehanFazal77/nephio-workload-blueprints.git
    directory: workloads/oai-ran/oai-ran/oai-amf
    ref: main
    commit: e9854b1648d0394c2a359a6b0c043747adb1a1e3
info:
  description: example amf blueprint package
  readinessGates:
  - conditionType: config.injection.WorkloadCluster.workload-cluster
  - conditionType: nephio.org.Specializer.specialize
pipeline:
  mutators:
  - image: ghcr.io/kptdev/krm-functions-catalog/apply-replacements:v0.1.1
    configPath: apply-replacements-owner.yaml
  - image: ghcr.io/kptdev/krm-functions-catalog/apply-replacements:v0.1.1
    configPath: apply-replacements-namespace.yaml
  - image: ghcr.io/kptdev/krm-functions-catalog/set-namespace:v0.4.1
    configPath: cm-namespace.yaml
  - image: docker.io/nephio/nfdeploy-fn:latest
  - image: docker.io/nephio/interface-fn:latest
  - image: docker.io/nephio/nad-fn:latest
  - image: docker.io/nephio/interface-fn:latest
  - image: docker.io/nephio/nfdeploy-fn:latest
status:
  conditions:
  - type: config.injection.WorkloadCluster.workload-cluster
    status: "True"
    message: injected resource "ran" from cluster
    reason: ConfigInjected
  - message: update done
    reason: req.nephio.org/v1alpha1.Interface.n2
    status: "True"
    type: ipam.resource.nephio.org/v1alpha1.IPClaim.amf-ran-n2-ipv4
  - message: update done
    reason: req.nephio.org/v1alpha1.Interface.n2
    status: "True"
    type: k8s.cni.cncf.io/v1.NetworkAttachmentDefinition.amf-ran-n2
  - reason: Ready
    status: "True"
    type: nephio.org.Specializer.specialize
  - message: child local resource -> done
    reason: workload.nephio.org/v1alpha1.NFDeployment.amf-ran
    status: "True"
    type: req.nephio.org/v1alpha1.Capacity.control-plane
  - message: update done
    status: "True"
    type: req.nephio.org/v1alpha1.Interface.n2
    reason: workload.nephio.org/v1alpha1.NFDeployment.amf-ran
  - message: update done
    status: "True"
    type: req.nephio.org/v1alpha1.Interface.sbi
    reason: workload.nephio.org/v1alpha1.NFDeployment.amf-ran
  - message: update done
    reason: req.nephio.org/v1alpha1.Interface.n2
    status: "True"
    type: vlan.resource.nephio.org/v1alpha1.VLANClaim.amf-ran-n2
  - message: update done
    status: "True"
    type: workload.nephio.org/v1alpha1.NFDeployment.amf-ran
